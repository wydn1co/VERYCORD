# Discord Bot Token
BOT_TOKEN=your_bot_token_here

# Discord Application OAuth2
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# OAuth2 Redirect URI (must match Discord Developer Portal)
# You need TWO redirect URIs in your Discord app settings:
# 1. https://your-domain.com/auth/callback (for verification)
# 2. https://your-domain.com/dashboard/callback (for dashboard login)
REDIRECT_URI=https://verycord-production.up.railway.app/auth/callback

# Web Server
PORT=3000
BASE_URL=https://verycord-production.up.railway.app

# Email Settings (for sending backup notifications to owners)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
